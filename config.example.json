{
  "_comment": "Copy to config.json and set bhaptics.appId, apiKey.",
  "ui": {
    "port": 1969
  },
  "osc": {
    "port": 9001,
    "host": "127.0.0.1",
    "autoFreePorts": true
  },
  "bhaptics": {
    "appId": "{your appId}",
    "apiKey": "{your apiKey}",
    "remote": "127.0.0.1:15881"
  },
  "intensity": {
    "impactThreshold": 0.4,
    "velocityMin": 0.2,
    "velocityMax": 5.0,
    "durationMin": 0.1,
    "durationMax": 1.25,
    "longContactMs": 2000,
    "emaAlpha": 0.4,
    "cooldownMs": 30,
    "sustainCooldownMs": 150,
    "minIntensity": 0.1,
    "maxIntensity": 1.8
  },
  "haptic": {
    "useDotMode": true,
    "motorClusterSize": 0
  },
  "contactParams": {
    "value": "ContactChest",
    "speed": "ContactSpeed",
    "zone": "ContactZone",
    "acceptAll": false,
    "excludeFaceTracking": true,
    "contactTimeoutMs": 250,
    "extra": [],
    "ignore": ["touch/headpat", "touch/boop", "Touch/FootLeft", "Touch/FootRight", "VF108_superneko.realkiss.contact.activator"]
  }
}
